# ── Django Core Settings ──────────────────────────────────────────────
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=django-insecure-your-secret-key-here
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database Configurations ───────────────────────────────────────────
# To use SQLite (e.g. for local development), comment out the DB_* lines below.
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=5432

# ── Directory Configurations (Safe Outside-Backend Storage) ──────────
# Set these on cPanel/Production to folders outside the backend/ directory.
DJANGO_MEDIA_ROOT=
DJANGO_STATIC_ROOT=

# ── Administrative Credentials (Optional helper vars) ─────────────────
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=change_this_password
